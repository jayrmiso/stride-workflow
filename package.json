{
  "name": "stride-workflow",
  "version": "1.0.39",
  "description": "Spec-and-impl workflow scaffolding for Codex-first repo work.",
  "type": "module",
  "bin": {
    "stride-workflow": "./bin/stride-workflow.js"
  },
  "files": [
    "bin",
    "templates",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "npx playwright install chromium",
    "check": "node --check bin/stride-workflow.js",
    "smoke": "node bin/stride-workflow.js --help && node bin/stride-workflow.js version && node bin/stride-workflow.js command kit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayrmiso/stride-workflow.git"
  },
  "keywords": [
    "codex",
    "workflow",
    "cli",
    "ai",
    "worktree"
  ],
  "dependencies": {
    "playwright": "1.61.1"
  },
  "license": "MIT"
}
